{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/air-quality-programmatic-apis/refs/heads/main/json-structure/aqicn-attribution-structure.json",
  "name": "Attribution",
  "description": "Data source attribution",
  "type": "object",
  "properties": {
    "url": {
      "type": "string",
      "description": "Attribution URL",
      "example": "https://www.epa.gov/airnow"
    },
    "name": {
      "type": "string",
      "description": "Data source name",
      "example": "US EPA AirNow"
    }
  }
}